# Requirements Chatbot Configuration
# Copy this file to .env and update with your values

# Excel File Path
# Path to your requirements Excel file
EXCEL_FILE=data.xlsx


# Copy this file to .env and update with your values

# RAG Backend Selection
# Options: "chromadb" or "neo4j"
RAG_BACKEND=chromadb

# Neo4j Configuration (only needed if RAG_BACKEND=neo4j)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# LLM Backend Selection
# Options: "ollama", "openai", or "template"
LLM_BACKEND=ollama

# LLM Model Selection
# For Ollama: "llama3.2", "mistral", "phi3", etc.
# For OpenAI: "gpt-4o-mini", "gpt-4o", etc.
LLM_MODEL=llama3.2

# Retrieval and generation tuning
# How many chunks to retrieve for each response
RAG_TOP_K=5
# Lower values are more deterministic (recommended for requirements elicitation)
OPENAI_TEMPERATURE=0.4
# Response length cap
OPENAI_MAX_TOKENS=280
# Ollama nucleus sampling (used only for Ollama backend)
OLLAMA_TOP_P=0.9

# Runtime tweak mode (feedback loop + tweak file application)
# When false, /api/feedback is disabled and response tweaks are not applied
TWEAK_MODE_ENABLED=false
# Path to behavior tweak file used when tweak mode is enabled
BEHAVIOR_TWEAKS_FILE=behavior_tweaks.json

# OpenAI Configuration (only needed if LLM_BACKEND=openai)
# OPENAI_API_KEY=your-api-key-here
